    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst vehicles = input.data;\n\nif (!Array.isArray(vehicles) || vehicles.length === 0) {\n  console.log('No vehicles found in API response');\n  return [{ json: { error: 'No vehicles found', skip: true } }];\n}\n\nconsole.log(`Processing ${vehicles.length} vehicles from API`);\n\nconst results = [];\n\nfor (let i = 0; i < vehicles.length; i++) {\n  const v = vehicles[i];\n  \n  const year = (v.makeYear || '').toString();\n  const brand = (v.brandName || '').toString();\n  const model = (v.modelName || '').toString();\n  \n  if (!year || !brand || !model) {\n    console.warn(`Skipping vehicle ${i}: missing year/brand/model`);\n    continue;\n  }\n  \n  const monthlyPayment = parseFloat(v.priceWithTax || v.priceNoTax || 0);\n  const termMonths = parseInt(v.leaseMonths || 36);\n  const msrp = parseFloat(v.msrp || 0);\n  \n  results.push({\n    json: {\n      vehicleID: (v.vehicleID || '').toString(),\n      year: year,\n      brand: brand,\n      model: model,\n      fullName: v.vehicleName || `${year} ${brand} ${model}`,\n      variant: v.variantName || '',\n      status: v.conditionName || 'Available',\n      fuelType: v.fuelTypeName || '',\n      msrp: msrp.toFixed(2),\n      monthlyPayment: monthlyPayment.toFixed(2),\n      termMonths: termMonths.toString(),\n      totalLeaseCost: (monthlyPayment * termMonths).toFixed(2),\n      milesPerYear: (v.milesPerYear || '').toString(),\n      downPayment: (v.downPayment || 0).toString(),\n      brokerFee: (v.brokerFee || 0).toString(),\n      stockNumber: v.registrationNo || '',\n      lastUpdated: new Date().toLocaleString('en-US', { timeZone: 'America/New_York' })\n    }\n  });\n}\n\nconsole.log(`Returning ${results.length} vehicles`);\n\nif (results.length === 0) {\n  return [{ json: { error: 'No valid vehicles after transformation', skip: true } }];\n}\n\nreturn results;"
      },
