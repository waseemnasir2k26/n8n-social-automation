    {
      "parameters": {
        "jsCode": "const webhookData = $input.item.json;\n\n// Check if this is a verification request (no body/entry)\nif (!webhookData.body?.entry?.[0]?.messaging?.[0]) {\n  return {\n    json: {\n      isVerification: true,\n      skipProcessing: true\n    }\n  };\n}\n\nconst messaging = webhookData.body.entry[0].messaging[0];\n\n// Skip echo messages (messages sent by the page itself)\nif (messaging.message?.is_echo) {\n  return {\n    json: {\n      isEcho: true,\n      skipProcessing: true\n    }\n  };\n}\n\nconst message = messaging.message?.text || '';\nconst senderId = messaging.sender?.id || '';\nconst recipientId = messaging.recipient?.id || '';\n\n// Skip if no sender ID\nif (!senderId) {\n  return {\n    json: {\n      skipProcessing: true,\n      reason: 'No sender ID'\n    }\n  };\n}\n\nconst customerName = messaging.sender?.name || `Customer ${senderId.substring(0, 8)}`;\n\nlet imageUrl = null;\nconst attachments = messaging.message?.attachments || [];\n\nif (attachments.length > 0) {\n  const imageAttachment = attachments.find(att => att.type === 'image' || att.type === 'photo');\n  imageUrl = imageAttachment?.payload?.url || imageAttachment?.payload?.src || null;\n}\n\nif (!imageUrl && messaging.message?.image_url) {\n  imageUrl = messaging.message.image_url;\n}\n\nif (!imageUrl && messaging.message?.media) {\n  imageUrl = messaging.message.media.url || messaging.message.media.src || null;\n}\n\n// Skip if no message content and no image\nif (!message && !imageUrl) {\n  return {\n    json: {\n      skipProcessing: true,\n      reason: 'No message content'\n    }\n  };\n}\n\nreturn {\n  json: {\n    chatInput: message || (imageUrl ? '[Image sent]' : ''),\n    sessionId: senderId,\n    senderId: senderId,\n    recipientId: recipientId,\n    customerName: customerName,\n    imageUrl: imageUrl,\n    hasImage: imageUrl !== null,\n    skipProcessing: false,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
