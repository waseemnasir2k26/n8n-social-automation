      "parameters": {
        "jsCode": "const items = $input.all();\nconst totalVehicles = items.length;\n\nconst brandCounts = {};\nitems.forEach(item => {\n  const brand = item.json.brand;\n  if (brand) brandCounts[brand] = (brandCounts[brand] || 0) + 1;\n});\n\nconst brandSummary = Object.entries(brandCounts)\n  .sort((a, b) => b[1] - a[1])\n  .map(([brand, count]) => `${brand}: ${count}`)\n  .join(', ');\n\nconst summary = `Sync Complete: ${totalVehicles} vehicles\\nBrands: ${brandSummary}`;\n\nconsole.log(summary);\n\nreturn {\n  json: {\n    success: true,\n    totalVehicles: totalVehicles,\n    brandBreakdown: brandCounts,\n    summary: summary,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
