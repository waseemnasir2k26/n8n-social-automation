    {
      "parameters": {
        "jsCode": "// Extract the draft content\nconst response = $input.first().json;\nconst previousData = $('Parse & Filter Score >= 7').item.json;\n\nlet draft = response.message?.content || response.text || '';\ndraft = draft.trim().slice(0, 3000);\n\nconst wordCount = draft.split(/\\s+/).filter(w => w).length;\n\nreturn [{\n  json: {\n    ...previousData,\n    draft: draft,\n    wordCount: wordCount,\n    createdAt: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-draft",
      "name": "Extract Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 300]
