    {
      "parameters": {
        "jsCode": "// Process all RSS items and normalize them\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  const normalized = {\n    title: (data.title || '').slice(0, 300),\n    description: (data.contentSnippet || data.description || '').replace(/<[^>]*>/g, '').slice(0, 500),\n    url: data.link || data.url || '',\n    source: data.creator || data.author || 'Unknown',\n    publishedAt: data.pubDate || data.isoDate || new Date().toISOString(),\n    hash: Buffer.from((data.title || '') + (data.link || '')).toString('base64').slice(0, 24)\n  };\n  \n  // Only include if has title and url\n  if (normalized.title && normalized.url) {\n    results.push({ json: normalized });\n  }\n}\n\n// Limit to first 10 items to avoid rate limits\nreturn results.slice(0, 10);"
      },
      "id": "normalize",
      "name": "Normalize All Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [120, 300]
    },
    {
      "parameters": {
        "operation": "search",
        "base": {
          "__rl": true,
          "value": "={{ $env.AIRTABLE_BASE_ID }}",
          "mode": "id"
