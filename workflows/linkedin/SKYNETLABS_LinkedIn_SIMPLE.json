      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [340, 300],
      "credentials": {
        "airtableTokenApi": {
          "id": "e0hiAgHt6nNNHNd0",
          "name": "Airtable Personal Access Token account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check if this item was already processed\nconst input = $input.first().json;\nconst normalizedItem = $('Normalize All Items').item.json;\n\n// If records array is empty, it's a new item\nconst isNew = !input.records || input.records.length === 0;\n\nif (isNew) {\n  return [{ json: { ...normalizedItem, isNew: true } }];\n} else {\n  // Return empty to skip this item\n  return [];\n}"
      },
      "id": "filter-new",
      "name": "Filter New Only",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 300]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "You are a content editor for SkynetLabs, a B2B AI automation agency.\n\nServices: AI Video, Voice Agents, Workflow Automation, CRM Automation, Social Automation, Chatbots.\n\nScore this news item for LinkedIn content potential.\n\nRESPOND WITH JSON ONLY:\n{\"score\": 0-10, \"category\": \"AI|Automation|SaaS|Business|Tech\", \"angle\": \"brief content angle\", \"reason\": \"1 sentence\"}",
              "role": "system"
            },
            {
              "content": "=Score this:\n\nTitle: {{ $json.title }}\n\nDescription: {{ $json.description }}"
            }
          ]
        },
        "options": {
          "maxTokens": 150,
          "temperature": 0.1
        }
      },
      "id": "gpt4o-mini-filter",
      "name": "GPT-4o-mini Filter",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [780, 300],
      "credentials": {
        "openAiApi": {
          "id": "AevMS99UaDEkMJw8",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse GPT response and check score\nconst response = $input.first().json;\nconst originalItem = $('Filter New Only').item.json;\n\nlet parsed = { score: 0, category: 'Other', angle: '', reason: '' };\n\ntry {\n  let content = response.message?.content || response.text || JSON.stringify(response);\n  content = content.replace(/```json\\n?/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(content);\n  \n  if (typeof parsed.score !== 'number') {\n    parsed.score = parseInt(parsed.score) || 0;\n  }\n  parsed.score = Math.max(0, Math.min(10, parsed.score));\n} catch (e) {\n  parsed.score = 0;\n  parsed.reason = 'Parse error';\n}\n\n// Only continue if score >= 7\nif (parsed.score >= 7) {\n  return [{\n    json: {\n      ...originalItem,\n      filter: {\n        score: parsed.score,\n        category: parsed.category || 'Other',\n        angle: parsed.angle || '',\n        reason: parsed.reason || ''\n      }\n    }\n  }];\n} else {\n  // Log to ProcessedItems and stop\n  return [];\n}"
      },
      "id": "parse-filter",
      "name": "Parse & Filter Score >= 7",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o",
          "mode": "list",
          "cachedResultName": "GPT-4o"
        },
        "messages": {
          "values": [
            {
              "content": "You are a ghostwriter for a B2B Tech Founder who runs SkynetLabs, a premium AI automation agency.\n\nBRAND VOICE:\n- Professional yet approachable\n- Insightful, not preachy\n- Practical over theoretical\n- Confident but not arrogant\n\nFORMAT RULES:\n- Short paragraphs (1-3 lines)\n- NO hashtags in body (add 3 at very end)\n- NO emojis\n- 150-250 words\n\nSTRUCTURE:\n1. Hook (1-2 lines) - Pattern interrupt\n2. Insight (2-3 lines) - Core observation\n3. Evidence (2-3 lines) - Data or example\n4. Takeaway (1-2 lines) - Implication\n5. CTA (1 line) - Soft question\n\nNEVER start with \"I\" or use clickbait.",
              "role": "system"
            },
            {
              "content": "=Write ONE LinkedIn post for this:\n\nTOPIC: {{ $json.title }}\nDESCRIPTION: {{ $json.description }}\nANGLE: {{ $json.filter.angle }}\n\nWrite a single compelling LinkedIn post. No variations needed."
            }
          ]
        },
        "options": {
          "maxTokens": 800,
          "temperature": 0.7
        }
      },
      "id": "gpt4o-draft",
      "name": "GPT-4o Write Post",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1220, 300],
      "credentials": {
        "openAiApi": {
          "id": "AevMS99UaDEkMJw8",
          "name": "OpenAi account"
        }
